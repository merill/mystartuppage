---
interface Props {
  title: string
  description?: string
  author: string
  linkedin?: string
  screenshot: string
  settingsUrl: string
  slug: string
}

const { title, description, author, linkedin, screenshot, settingsUrl, slug } = Astro.props
---

<div class="theme-card" data-title={title.toLowerCase()} data-author={author.toLowerCase()} data-description={(description || '').toLowerCase()}>
  <div class="theme-screenshot">
    <img src={screenshot} alt={`${title} theme screenshot`} loading="lazy" />
  </div>
  <div class="theme-info">
    <h3>{title}</h3>
    {description && <p class="theme-desc">{description}</p>}
    <div class="theme-meta">
      <span class="theme-author">
        by{' '}
        {linkedin ? (
          <a href={linkedin} rel="noreferrer noopener" target="_blank">{author}</a>
        ) : (
          author
        )}
      </span>
    </div>
    <div class="theme-actions">
      <a href={settingsUrl} download={`${slug}.json`} class="btn btn-primary btn-sm">
        Download settings
      </a>
    </div>
  </div>
</div>

<style>
  .theme-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .theme-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .theme-screenshot {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .theme-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .theme-info {
    padding: 20px;
  }

  h3 {
    font-size: 1.1rem;
    margin-bottom: 4px;
  }

  .theme-desc {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    margin-bottom: 8px;
  }

  .theme-meta {
    margin-bottom: 12px;
  }

  .theme-author {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .theme-author a {
    color: var(--color-primary);
  }

  .theme-actions {
    display: flex;
    gap: 8px;
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 0.85rem;
  }
</style>
