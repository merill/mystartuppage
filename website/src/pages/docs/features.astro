---
import Base from '../../layouts/Base.astro'
---

<Base title="Features Moved - Yako Docs" description="Yako features are now part of the overview page.">
  <Fragment slot="head">
    <meta http-equiv="refresh" content="0; url=/docs/overview/" />
    <link rel="canonical" href="/docs/overview/" />
  </Fragment>

  <main class="redirect-page">
    <h1>Features Moved</h1>
    <p>The features overview is now part of the <a href="/docs/overview/">Yako overview</a>.</p>
  </main>
</Base>

<script>
  window.location.replace('/docs/overview/')
</script>

<style>
  .redirect-page {
    min-height: 60vh;
    max-width: 720px;
    margin: 0 auto;
    padding: 96px 24px;
    text-align: center;
  }

  .redirect-page p {
    margin-top: 16px;
    color: var(--color-text-secondary);
  }
</style>
