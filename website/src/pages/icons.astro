---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Base
  title="Microsoft Cloud Icon Library - Yako"
  description="Search and copy direct URLs for Microsoft Cloud icons to use when contributing to msportals.io and cmd.ms."
>
  <Nav slot="nav" />

  <div class="container icons-page">
    <header class="icons-header">
      <h1>Microsoft Cloud Icon Library</h1>
      <p class="icons-sub">
        Search and find direct URLs for Microsoft Cloud icons to use when contributing to
        <a href="https://github.com/adamfowlerit/msportals.io/tree/master/_data/portals" rel="noreferrer noopener">msportals.io</a>
        and <a href="https://github.com/merill/cmd/blob/main/website/config/commands.csv" rel="noreferrer noopener">cmd.ms</a>.
      </p>
      <p class="icons-sub">
        <strong>How to use:</strong> click an icon to copy its URL to your clipboard, then paste it into the relevant entry in
        <a href="https://github.com/adamfowlerit/msportals.io/tree/master/_data/portals" rel="noreferrer noopener"><code>_data/portals/*.json</code></a>
        (msportals.io) or
        <a href="https://github.com/merill/cmd/blob/main/website/config/commands.csv" rel="noreferrer noopener"><code>commands.csv</code></a> (cmd.ms).
      </p>
      <p class="icons-credit">
        Icons referenced from
        <a href="https://www.mscloudlogos.com/" rel="noreferrer noopener">mscloudlogos.com</a>
      </p>
    </header>

    <div class="icon-viewer-topbar">
      <input
        id="icon-viewer-search"
        type="text"
        placeholder="Search icons..."
        maxlength="100"
        autocomplete="off"
        spellcheck="false"
      />
    </div>

    <div id="icon-viewer-filters" class="icon-viewer-filters" role="group" aria-label="Filter icons by category"></div>

    <div id="icon-viewer-loading" class="icon-viewer-loading">
      <div class="icon-viewer-spinner"></div>
      <span>Loading icons...</span>
    </div>

    <div id="icon-viewer-grid" class="icon-viewer-grid"></div>

    <div id="icon-viewer-toast" class="icon-viewer-toast" aria-live="polite"></div>
  </div>

  <Footer slot="footer" />
</Base>

<style is:global>
  .icons-page {
    max-width: 1200px;
    padding-top: 48px;
    padding-bottom: 96px;
  }

  .icons-header {
    max-width: 820px;
    margin: 0 auto 32px;
    text-align: center;
  }

  .icons-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  @media (min-width: 640px) {
    .icons-header h1 {
      font-size: 2.5rem;
    }
  }

  .icons-sub {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.65;
    margin-bottom: 10px;
  }

  .icons-sub a {
    color: var(--color-text);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .icons-sub a:hover {
    color: var(--color-primary);
  }

  .icons-sub code {
    padding: 1px 6px;
    border-radius: 4px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    font-size: 0.85em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .icons-header strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .icons-credit {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .icons-credit a {
    color: var(--color-text);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .icons-credit a:hover {
    color: var(--color-text-secondary);
  }

  /* ─── Top bar ─── */
  .icon-viewer-topbar {
    position: sticky;
    top: calc(var(--nav-height) + 8px);
    z-index: 10;
    display: flex;
    gap: 12px;
    align-items: center;
    max-width: 960px;
    margin: 0 auto 24px;
    padding: 12px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  #icon-viewer-search {
    flex: 1;
    min-width: 0;
    padding: 10px 14px;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }

  #icon-viewer-search:focus {
    border-color: var(--color-primary);
  }

  /* ─── Category filter pills (shadcn-style) ─── */
  .icon-viewer-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    max-width: 1200px;
    margin: 0 auto 20px;
    padding: 0 4px;
  }

  .icon-viewer-filter {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    transition: background-color 0.12s, border-color 0.12s, color 0.12s, transform 0.08s;
  }

  .icon-viewer-filter:hover {
    border-color: color-mix(in srgb, var(--color-border) 40%, var(--color-text));
    background: var(--color-bg-alt);
  }

  .icon-viewer-filter:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 25%, transparent);
    border-color: var(--color-primary);
  }

  .icon-viewer-filter:active {
    transform: scale(0.97);
  }

  .icon-viewer-filter.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .icon-viewer-filter-count {
    font-variant-numeric: tabular-nums;
    font-weight: 400;
    opacity: 0.7;
    font-size: 0.78rem;
  }

  .icon-viewer-filter.active .icon-viewer-filter-count {
    opacity: 0.75;
  }

  /* ─── Loading ─── */
  .icon-viewer-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 96px 24px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .icon-viewer-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: icon-viewer-spin 0.8s linear infinite;
  }

  @keyframes icon-viewer-spin {
    to { transform: rotate(360deg); }
  }

  /* ─── Groups ─── */
  .icon-viewer-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .icon-viewer-group {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    padding: 20px;
  }

  .icon-viewer-group h2 {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
    color: var(--color-text);
  }

  .icon-viewer-items {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(84px, 1fr));
    gap: 4px;
  }

  @media (max-width: 600px) {
    .icon-viewer-items {
      grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    }
  }

  /* ─── Tile ─── */
  .icon-viewer-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 4px;
    padding: 6px 4px 6px;
    border-radius: var(--radius);
    border: 2px solid transparent;
    background: transparent;
    cursor: pointer;
    transition: background-color 0.12s, border-color 0.12s;
    text-align: center;
  }

  .icon-viewer-item:hover {
    background: var(--color-bg-alt);
    border-color: var(--color-primary);
  }

  .icon-viewer-item-icon {
    width: 100%;
    aspect-ratio: 1;
    height: auto;
    padding: 8%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-viewer-item-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Monochrome (black-only) SVGs are invisible on dark backgrounds — flip them white. */
  [data-theme='dark'] .icon-viewer-item.monochrome .icon-viewer-item-icon img {
    filter: invert(1);
  }

  .icon-viewer-item-name {
    font-size: 0.72rem;
    line-height: 1.3;
    color: var(--color-text-secondary);
    opacity: 0.85;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: break-word;
    width: 100%;
  }

  /* ─── Copy button (appears on hover) ─── */
  .icon-viewer-copy-btn {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.12s, background-color 0.12s, color 0.12s;
  }

  .icon-viewer-item:hover .icon-viewer-copy-btn,
  .icon-viewer-copy-btn:focus-visible {
    opacity: 1;
  }

  .icon-viewer-copy-btn:hover {
    background: var(--color-primary);
    color: var(--color-bg);
  }

  .icon-viewer-copy-btn svg {
    width: 12px;
    height: 12px;
  }

  .icon-viewer-copy-btn.copied {
    opacity: 1;
    background: #16a34a;
    color: #fff;
    border-color: #16a34a;
  }

  /* ─── No results ─── */
  .icon-viewer-no-results {
    text-align: center;
    padding: 64px 24px;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  /* ─── Toast ─── */
  .icon-viewer-toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    padding: 10px 18px;
    border-radius: var(--radius);
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 0.85rem;
    font-weight: 500;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 1000;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .icon-viewer-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
  // ─── Config ───
  const CATALOG_URL = '/ms/catalog.json'
  const ICON_BASE_URL = '/ms/'

  // ─── Types ───
  interface CatalogEntry {
    id: string
    name: string
    altnames: string
    group: string
    icon: string
    source: 'product' | 'icon'
    type?: string
    prodfamilies?: string[]
    monochrome?: boolean
  }

  // ─── State ───
  let products: CatalogEntry[] = []
  // 'All' (or empty string) means no filtering; otherwise only that one group is shown
  let activeGroup = 'All'
  let toastTimer: number | null = null

  // ─── DOM ───
  const searchEl = document.getElementById('icon-viewer-search') as HTMLInputElement | null
  const filtersEl = document.getElementById('icon-viewer-filters') as HTMLDivElement | null
  const loadingEl = document.getElementById('icon-viewer-loading') as HTMLDivElement | null
  const gridEl = document.getElementById('icon-viewer-grid') as HTMLDivElement | null
  const toastEl = document.getElementById('icon-viewer-toast') as HTMLDivElement | null

  searchEl?.addEventListener('input', () => renderGrid())

  // ─── Boot ───
  loadProducts()

  async function loadProducts(): Promise<void> {
    try {
      const response = await fetch(CATALOG_URL)
      if (!response.ok) {
        showError('Failed to load icons (HTTP ' + response.status + ').')
        return
      }

      const data = await response.json() as { entries: CatalogEntry[] }
      products = data.entries ?? []
    } catch (err) {
      console.error('Icon viewer: failed to load products manifest', err)
      showError('Failed to load icons.')
      return
    }

    if (loadingEl) loadingEl.style.display = 'none'
    renderCategoryFilters()
    renderGrid()
  }

  function showError(message: string): void {
    if (!loadingEl) return
    loadingEl.innerHTML = ''
    const span = document.createElement('span')
    span.textContent = message
    loadingEl.appendChild(span)
  }

  // ─── Category filter pills ───

  function renderCategoryFilters(): void {
    if (!filtersEl) return

    filtersEl.innerHTML = ''

    // "All" pill
    filtersEl.appendChild(createFilterPill('All', products.length, activeGroup === 'All', () => {
      setActiveGroup('All')
    }))

    // One pill per category with its icon count
    for (const g of getGroups()) {
      const count = products.reduce((n, p) => p.group === g ? n + 1 : n, 0)
      filtersEl.appendChild(createFilterPill(g, count, activeGroup === g, () => {
        setActiveGroup(g)
      }))
    }
  }

  function setActiveGroup(group: string): void {
    if (activeGroup === group) return
    activeGroup = group
    updateFilterActiveStates()
    renderGrid()
  }

  function createFilterPill(label: string, count: number, active: boolean, onClick: () => void): HTMLButtonElement {
    const btn = document.createElement('button')
    btn.type = 'button'
    btn.className = 'icon-viewer-filter' + (active ? ' active' : '')
    btn.dataset.group = label
    btn.setAttribute('aria-pressed', active ? 'true' : 'false')

    const labelEl = document.createElement('span')
    labelEl.textContent = label
    btn.appendChild(labelEl)

    const countEl = document.createElement('span')
    countEl.className = 'icon-viewer-filter-count'
    countEl.textContent = String(count)
    btn.appendChild(countEl)

    btn.addEventListener('click', onClick)
    return btn
  }

  function updateFilterActiveStates(): void {
    if (!filtersEl) return
    for (const btn of filtersEl.querySelectorAll<HTMLButtonElement>('.icon-viewer-filter')) {
      const g = btn.dataset.group ?? ''
      const isActive = g === activeGroup
      btn.classList.toggle('active', isActive)
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false')
    }
  }

  function getGroups(): string[] {
    const set = new Set<string>()
    for (const p of products) set.add(p.group)
    return Array.from(set).sort((a, b) => a.localeCompare(b))
  }

  // ─── Render ───

  function renderGrid(): void {
    if (!gridEl) return

    gridEl.innerHTML = ''

    const query = (searchEl?.value ?? '').toLowerCase().trim()
    const tokens = query ? query.split(/\s+/).filter(Boolean) : []

    let filtered = products

    if (tokens.length > 0) {
      filtered = filtered.filter((p) => {
        const fams = p.prodfamilies ? p.prodfamilies.join(' ') : ''
        const haystack = (p.name + ' ' + p.altnames + ' ' + p.group + ' ' + fams).toLowerCase()
        return tokens.every((token) => haystack.includes(token))
      })
    }

    if (activeGroup !== 'All') {
      filtered = filtered.filter((p) => p.group === activeGroup)
    }

    if (filtered.length === 0) {
      const noRes = document.createElement('div')
      noRes.className = 'icon-viewer-no-results'
      noRes.textContent = 'No icons found.'
      gridEl.appendChild(noRes)
      return
    }

    const groups = new Map<string, CatalogEntry[]>()
    for (const p of filtered) {
      const list = groups.get(p.group)
      if (list) list.push(p)
      else groups.set(p.group, [p])
    }

    const orderedGroups = getGroups()

    for (const g of orderedGroups) {
      const groupProducts = groups.get(g)
      if (!groupProducts || groupProducts.length === 0) continue

      groupProducts.sort((a, b) => a.name.localeCompare(b.name))

      const panel = document.createElement('div')
      panel.className = 'icon-viewer-group'

      const titleEl = document.createElement('h2')
      titleEl.textContent = g + ' (' + groupProducts.length + ')'
      panel.appendChild(titleEl)

      const itemsContainer = document.createElement('div')
      itemsContainer.className = 'icon-viewer-items'

      for (const product of groupProducts) {
        itemsContainer.appendChild(createIconTile(product))
      }

      panel.appendChild(itemsContainer)
      gridEl.appendChild(panel)
    }
  }

  function createIconTile(product: CatalogEntry): HTMLDivElement {
    const item = document.createElement('div')
    item.className = 'icon-viewer-item' + (product.monochrome ? ' monochrome' : '')
    const altLabel = product.altnames ? ' (' + product.altnames + ')' : ''
    item.title = 'Click to copy URL - ' + product.name + altLabel
    item.setAttribute('role', 'button')
    item.setAttribute('tabindex', '0')

    const relativeUrl = ICON_BASE_URL + encodeURI(product.icon)
    const absoluteUrl = new URL(relativeUrl, location.origin).href

    const iconWrap = document.createElement('div')
    iconWrap.className = 'icon-viewer-item-icon'

    const img = document.createElement('img')
    img.src = relativeUrl
    img.alt = product.name
    img.loading = 'lazy'
    iconWrap.appendChild(img)

    const nameEl = document.createElement('span')
    nameEl.className = 'icon-viewer-item-name'
    nameEl.textContent = product.name

    const copyBtn = document.createElement('button')
    copyBtn.type = 'button'
    copyBtn.className = 'icon-viewer-copy-btn'
    copyBtn.setAttribute('aria-label', 'Copy icon URL')
    copyBtn.innerHTML =
      '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" ' +
      'stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">' +
      '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>' +
      '<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>' +
      '</svg>'

    copyBtn.addEventListener('click', (e) => {
      e.stopPropagation()
      copyUrl(absoluteUrl, copyBtn)
    })

    item.appendChild(iconWrap)
    item.appendChild(nameEl)
    item.appendChild(copyBtn)

    item.addEventListener('click', () => copyUrl(absoluteUrl, copyBtn))
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        copyUrl(absoluteUrl, copyBtn)
      }
    })

    return item
  }

  // ─── Copy ───

  function copyUrl(url: string, btn: HTMLButtonElement): void {
    const done = () => {
      btn.classList.add('copied')
      setTimeout(() => btn.classList.remove('copied'), 1200)
      showToast('Copied: ' + url)
    }

    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(url).then(done).catch(() => fallbackCopy(url, done))
    } else {
      fallbackCopy(url, done)
    }
  }

  function fallbackCopy(text: string, done: () => void): void {
    const textarea = document.createElement('textarea')
    textarea.value = text
    textarea.style.position = 'fixed'
    textarea.style.opacity = '0'
    document.body.appendChild(textarea)
    textarea.select()
    try {
      document.execCommand('copy')
      done()
    } catch (err) {
      console.error('Copy failed', err)
    }
    document.body.removeChild(textarea)
  }

  function showToast(message: string): void {
    if (!toastEl) return
    toastEl.textContent = message
    toastEl.classList.add('visible')

    if (toastTimer !== null) {
      clearTimeout(toastTimer)
    }
    toastTimer = window.setTimeout(() => {
      toastEl.classList.remove('visible')
      toastTimer = null
    }, 1800)
  }
</script>

