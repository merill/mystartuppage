---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import ThemeCard from '../../components/ThemeCard.astro'
import { getCollection } from 'astro:content'
import fs from 'node:fs'
import path from 'node:path'

const themes = await getCollection('themes')

// Sort by date descending
themes.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())

// For each theme, resolve the screenshot and settings paths
// We copy them to public at build time via the loop below
const themeData = themes.map(theme => {
  const slug = theme.id.replace(/\/index$/, '').replace(/\//g, '-') || theme.id
  const themeDirBase = `./src/content/themes/${slug}`

  // Find screenshot file (any common image extension)
  let screenshotSrc = ''
  for (const ext of ['png', 'jpg', 'jpeg', 'webp', 'gif']) {
    const screenshotPath = path.join(themeDirBase, `screenshot.${ext}`)
    if (fs.existsSync(screenshotPath)) {
      // Copy to public so it's served as a static file
      const destDir = `./public/themes/${slug}`
      fs.mkdirSync(destDir, { recursive: true })
      fs.copyFileSync(screenshotPath, `${destDir}/screenshot.${ext}`)
      screenshotSrc = `/themes/${slug}/screenshot.${ext}`

      // Also copy settings.json
      const settingsPath = path.join(themeDirBase, 'settings.json')
      if (fs.existsSync(settingsPath)) {
        fs.copyFileSync(settingsPath, `${destDir}/settings.json`)
      }
      break
    }
  }

  return {
    slug,
    title: theme.data.title,
    description: theme.data.description,
    author: theme.data.author,
    linkedin: theme.data.linkedin,
    screenshot: screenshotSrc,
    settingsUrl: `/themes/${slug}/settings.json`,
  }
})
---

<Base title="Community Themes - Yako" description="Browse and download community-created Yako themes.">
  <Nav slot="nav" />

  <div class="themes-page container">
    <div class="themes-header">
      <h1>Community Themes</h1>
      <p class="subtitle">
        Browse themes shared by the community. Download any theme's settings and import them into Yako.
      </p>
      <div class="themes-toolbar">
        <input
          type="search"
          id="theme-search"
          placeholder="Search themes..."
          autocomplete="off"
        />
        <a href="/docs/contribute/" class="btn btn-primary btn-sm">Submit your theme</a>
      </div>
    </div>

    {themeData.length === 0 && (
      <div class="themes-empty">
        <p>No themes yet. Be the first to <a href="/docs/contribute/">submit one</a>!</p>
      </div>
    )}

    <div class="themes-grid" id="themes-grid">
      {themeData.map(theme => (
        <ThemeCard
          title={theme.title}
          description={theme.description}
          author={theme.author}
          linkedin={theme.linkedin}
          screenshot={theme.screenshot}
          settingsUrl={theme.settingsUrl}
          slug={theme.slug}
        />
      ))}
    </div>

    <p class="themes-no-results" id="themes-no-results" style="display:none;">
      No themes match your search.
    </p>
  </div>

  <Footer slot="footer" />
</Base>

<script>
  const searchInput = document.getElementById('theme-search') as HTMLInputElement
  const grid = document.getElementById('themes-grid')!
  const noResults = document.getElementById('themes-no-results')!
  const cards = grid.querySelectorAll<HTMLElement>('.theme-card')

  searchInput.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim()
    let visibleCount = 0

    cards.forEach(card => {
      const title = card.dataset.title || ''
      const author = card.dataset.author || ''
      const description = card.dataset.description || ''
      const matches = !query || title.includes(query) || author.includes(query) || description.includes(query)

      card.style.display = matches ? '' : 'none'
      if (matches) visibleCount++
    })

    noResults.style.display = visibleCount === 0 ? '' : 'none'
  })
</script>

<style>
  .themes-page {
    padding: 40px 24px 80px;
  }

  .themes-header {
    margin-bottom: 32px;
  }

  .themes-header h1 {
    margin-bottom: 8px;
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin-bottom: 24px;
  }

  .themes-toolbar {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  #theme-search {
    flex: 1;
    padding: 10px 16px;
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s;
  }

  #theme-search:focus {
    border-color: var(--color-primary);
  }

  .themes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .themes-empty {
    text-align: center;
    padding: 64px 0;
    color: var(--color-text-secondary);
    font-size: 1.1rem;
  }

  .themes-no-results {
    text-align: center;
    padding: 48px 0;
    color: var(--color-text-secondary);
  }

  .btn-sm {
    padding: 10px 20px;
    font-size: 0.9rem;
    white-space: nowrap;
  }
</style>
